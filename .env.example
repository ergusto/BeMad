# Copy to `.env` and adjust as needed. Never commit a real `.env`.

# --- App ---
APP_PORT=3000

# --- Database (compose service name is `db`) ---
POSTGRES_USER=bemad
POSTGRES_PASSWORD=bemad
POSTGRES_DB=bemad

# Connection string the app uses (host is the `db` service inside compose).
# Leave commented to let compose derive it from the POSTGRES_* values above;
# set it explicitly only to point the app at a different database.
# DATABASE_URL=postgres://bemad:bemad@db:5432/bemad

# --- Test profile (`docker compose --profile test up -d db-test`) ---
POSTGRES_TEST_DB=bemad_test
TEST_DB_PORT=5433
# Used by the integration tests (run from the host) to reach the test DB.
TEST_DATABASE_URL=postgres://bemad:bemad@127.0.0.1:5433/bemad_test

# --- Dev profile (Adminer) ---
ADMINER_PORT=8080
